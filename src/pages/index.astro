---
// index.astro — Strona główna klienta (VoltsFlow template)
// Template: voltsflow | Reference: voltsflow-template.webflow.io
// Sekcje: Hero · Intro+Form · About · Services · Process · WhyUs · Stats · PhoneCTA · Pricing · Testimonials · Blog · CTA

import ClientLayout from '../layouts/ClientLayout.astro';
import {
  getAllClientLocations,
  getAssetsByClientId,
  getClientPage,
  getClientServices,
  getClientSiteConfig,
  getDesignProfileByClientId,
  getPublicAssetUrl,
  getClientPosts,
} from '../lib/client-data';
import { buildHomePageSchemas, buildFAQSchema, toSchemaScriptTag } from '../lib/schema';
import { getFallbackImages, getServiceFallback } from '../lib/fallback-images';

const clientId = import.meta.env.TEST_CLIENT_ID;
if (!clientId) throw new Error('Brak TEST_CLIENT_ID w env');

const [siteConfig, services, locations, homePage, profile, assets, posts] = await Promise.all([
  getClientSiteConfig(clientId),
  getClientServices(clientId),
  getAllClientLocations(clientId),
  getClientPage(clientId, 'home'),
  getDesignProfileByClientId(clientId),
  getAssetsByClientId(clientId),
  getClientPosts(clientId),
]);

// Assets
const logoAsset    = assets.find((a) => a.type === 'logo') ?? null;
const heroAsset    = assets.find((a) => a.type === 'hero') ?? null;
const teamAsset    = assets.find((a) => a.type === 'team') ?? null;
const serviceAssets = assets.filter((a) => a.type === 'service');
const galleryAssets = assets.filter((a) => a.type === 'gallery');

const logoUrl  = logoAsset  ? getPublicAssetUrl(logoAsset.storage_path)  : null;
const heroUrl  = heroAsset  ? getPublicAssetUrl(heroAsset.storage_path)  : null;
const teamUrl  = teamAsset  ? getPublicAssetUrl(teamAsset.storage_path)  : null;

// Fallback stock photos — dobierane per branża klienta
const fb = getFallbackImages(profile?.template_family, siteConfig?.industry ?? null);

const FALLBACK_HERO    = fb.hero;
const FALLBACK_TEAM    = fb.team;
const FALLBACK_PROCESS = fb.process;
const FALLBACK_WHY     = fb.why;

function svcImg(i: number): string {
  const pool = [...serviceAssets, ...galleryAssets];
  if (pool.length) return getPublicAssetUrl(pool[i % pool.length].storage_path);
  return getServiceFallback(fb, i);
}

// SEO
const pageTitle = homePage?.meta_title ?? `${siteConfig.site_name ?? siteConfig.city} — Profesjonalne usługi`;
const pageDesc  = homePage?.meta_description ?? `${siteConfig.site_name} — ${siteConfig.city}. ${services.map((s: { name: string }) => s.name).slice(0, 3).join(', ')}.`;
const domain    = siteConfig.domain ? `https://${siteConfig.domain.replace(/^https?:\/\//, '')}` : '';
const canonicalUrl = domain ? `${domain}/` : undefined;

const pageMeta   = homePage as any;
const faqItems: { question: string; answer: string }[] = pageMeta?.metadata?.faq ?? [];

const homeSchemas = buildHomePageSchemas({
  siteConfig,
  client: { company_name: siteConfig.site_name ?? '', industry: profile?.template_family ?? 'universal' },
  services,
  locations,
  logoUrl,
  heroUrl,
  description: pageDesc,
});
if (faqItems.length > 0) homeSchemas.push(buildFAQSchema({ items: faqItems }));
const schemaScripts = homeSchemas.map(toSchemaScriptTag);

// Pricing tiers — from metadata or fallback
const meta = (homePage as any)?.metadata ?? {};

const pricingTiers = meta.pricing_tiers ?? [
  {
    name: 'Podstawowy',
    tagline: 'Idealny dla małych zleceń',
    price_mo: 299,
    price_yr: 2690,
    desc: 'Drobne naprawy i konserwacje dla klientów indywidualnych.',
    features: ['Przegląd instalacji', 'Wymiana gniazdek / włączników', 'Konsultacja telefoniczna', 'Gwarancja 12 miesięcy'],
  },
  {
    name: 'Standardowy',
    tagline: 'Najpopularniejszy wybór',
    price_mo: 699,
    price_yr: 6290,
    desc: 'Kompleksowe usługi dla domów i małych firm z priorytetową obsługą.',
    features: ['Wszystko z planu Podstawowego', 'Instalacje od podstaw', 'Priorytetowy czas reakcji', 'Gwarancja 24 miesiące'],
    featured: true,
  },
  {
    name: 'Premium',
    tagline: 'Pełen zakres usług',
    price_mo: 1299,
    price_yr: 11690,
    desc: 'Rozwiązania dla deweloperów i dużych obiektów komercyjnych.',
    features: ['Wszystko z planu Standardowego', 'Dedykowany opiekun projektu', 'Dostępność 24/7', 'Gwarancja 36 miesięcy'],
  },
];

const testimonials = meta.testimonials ?? [
  { quote: 'Szybka realizacja, profesjonalna ekipa. Polecam z czystym sumieniem — wszystko zgodnie z umową i terminem.', author: 'Anna Kowalska', role: 'Właścicielka apartamentów', rating: 5 },
  { quote: 'Doskonały kontakt od pierwszego telefonu aż do odbioru prac. Jakość wykonania powyżej oczekiwań.', author: 'Marek Wiśniewski', role: 'Manager biurowca', rating: 5 },
  { quote: 'Ekipa jest naprawdę zaangażowana. Zostawili po sobie idealny porządek i wszystko działa bezbłędnie.', author: 'Katarzyna Nowak', role: 'Właścicielka domu', rating: 5 },
  { quote: 'Zaufałem im przy kompleksowym remoncie instalacji — nie zawiodłem się. Ceny zgodne z ofertą, zero niespodzianek.', author: 'Tomasz Grabowski', role: 'Inwestor', rating: 5 },
  { quote: 'Terminowość i rzetelność na najwyższym poziomie. Będę korzystał przy kolejnych inwestycjach.', author: 'Piotr Zając', role: 'Deweloper', rating: 5 },
];

const stats = meta.stats ?? [
  { number: '1250+', label: 'Zadowolonych klientów' },
  { number: '15+', label: 'Lat doświadczenia' },
  { number: '3200+', label: 'Zrealizowanych projektów' },
  { number: '98%', label: 'Pozytywnych opinii' },
];
---

<ClientLayout
  title={pageTitle}
  description={pageDesc}
  {canonicalUrl}
  {schemaScripts}
  designProfile={profile}
  {siteConfig}
  {logoUrl}
>
  <!-- footer-services slot -->
  {services.map((s: { name: string; slug: string }) => (
    <a slot="footer-services" href={`/uslugi/${s.slug}`}>{s.name}</a>
  ))}
  <!-- footer-locations slot -->
  {locations.map((l: { city: string; slug: string }) => (
    <a slot="footer-locations" href={`/lokalizacje/${l.slug}`}>{l.city}</a>
  ))}

  <!-- ═══════════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════════ -->
  <section class="vf-hero" aria-labelledby="hero-heading">
    <div
      class="vf-hero-bg"
      style={`background-image: url('${heroUrl ?? FALLBACK_HERO}')`}
      role="img"
      aria-label={heroAsset?.alt_text ?? `${siteConfig.site_name} — ${siteConfig.city}`}
    ></div>
    <div class="container">
      <div class="vf-hero-content">
        <div class="vf-hero-eyebrow">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          {siteConfig.city ?? 'Polska'}
        </div>
        <h1 id="hero-heading">
          {homePage?.title ?? `Profesjonalne usługi w ${siteConfig.city ?? 'Twojej okolicy'}`}
        </h1>
        <p>
          {pageDesc}
        </p>
        <div class="vf-hero-btns">
          {siteConfig.phone && (
            <a href={`tel:${siteConfig.phone.replace(/\s/g,'')}`} class="btn btn-primary" aria-label={`Zadzwoń: ${siteConfig.phone}`}>
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.68A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/></svg>
              Zadzwoń teraz
            </a>
          )}
          <a href="/kontakt" class="btn btn-outline-white">Umów wycenę</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       INTRO — value props + formularz
  ═══════════════════════════════════════════════════════════ -->
  <section class="section section-grey">
    <div class="container">
      <div class="vf-intro-grid">
        <!-- Value props -->
        <div class="vf-intro-points">
          <div class="vf-intro-point">
            <div class="vf-intro-icon" aria-hidden="true">
              <svg width="24" height="24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <div>
              <div class="vf-intro-title">Przystępne ceny</div>
              <p class="vf-intro-text">Usługi wysokiej jakości dopasowane do Twojego budżetu. Bez ukrytych kosztów.</p>
            </div>
          </div>
          <div class="vf-intro-point">
            <div class="vf-intro-icon" aria-hidden="true">
              <svg width="24" height="24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <div class="vf-intro-title">Szybka reakcja</div>
              <p class="vf-intro-text">Sprawna obsługa — odpowiadamy w ciągu godziny i przyjeżdżamy w ustalonym terminie.</p>
            </div>
          </div>
          <div class="vf-intro-point">
            <div class="vf-intro-icon" aria-hidden="true">
              <svg width="24" height="24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div>
              <div class="vf-intro-title">Gwarancja jakości</div>
              <p class="vf-intro-text">Każda usługa objęta jest gwarancją. Możesz liczyć na naszą odpowiedzialność za wynik.</p>
            </div>
          </div>
        </div>

        <!-- Formularz -->
        <div class="vf-intro-form">
          <div class="vf-intro-form-title">Twoje rozwiązanie zaczyna się tutaj!</div>
          <form class="vf-form" method="POST" action="/api/contact" novalidate>
            <div class="vf-field">
              <label class="vf-label" for="contact-name">Imię i nazwisko *</label>
              <input class="vf-input" id="contact-name" name="name" type="text" placeholder="Twoje imię" required autocomplete="name" />
            </div>
            <div class="vf-field">
              <label class="vf-label" for="contact-phone">Telefon *</label>
              <input class="vf-input" id="contact-phone" name="phone" type="tel" placeholder="Twój numer telefonu" required autocomplete="tel" />
            </div>
            <div class="vf-field">
              <label class="vf-label" for="contact-service">Rodzaj usługi</label>
              <select class="vf-select" id="contact-service" name="service">
                <option value="">Wybierz usługę</option>
                {services.map((s: { name: string; slug: string }) => (
                  <option value={s.slug}>{s.name}</option>
                ))}
              </select>
            </div>
            <button class="btn btn-primary vf-form-btn" type="submit">
              Wyślij zapytanie
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       ABOUT
  ═══════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="about-heading">
    <div class="container">
      <div class="grid-2">
        <!-- Zdjęcie -->
        <div class="vf-about-img-wrap">
          <img
            src={teamUrl ?? FALLBACK_TEAM}
            alt={teamAsset?.alt_text ?? `Zespół ${siteConfig.site_name}`}
            width="560" height="420"
            loading="lazy"
          />
          <div class="vf-about-rating" aria-label="Ocena klientów">
            <div class="vf-rating-num">4.9</div>
            <div class="vf-stars" aria-hidden="true">
              {[1,2,3,4,5].map(() => (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="#f59e0b"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ))}
            </div>
            <div class="vf-rating-label">Zweryfikowani klienci</div>
          </div>
        </div>

        <!-- Treść -->
        <div>
          <div class="label">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            O nas
          </div>
          <h2 id="about-heading">Solidne i bezpieczne usługi</h2>
          <div class="divider"></div>
          <p style="margin-bottom:24px;">
            Doświadczeni specjaliści działający na terenie {siteConfig.city ?? 'całej Polski'}.
            Zapewniamy bezpieczne, niezawodne rozwiązania dla domów i firm — z gwarancją i pełną odpowiedzialnością za wykonaną pracę.
          </p>
          <div class="vf-about-features">
            <div class="vf-about-feature">
              <div class="vf-feature-icon" aria-hidden="true">
                <svg width="18" height="18" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <div class="vf-feature-title">Bezpieczeństwo przede wszystkim</div>
                <p class="vf-feature-text">Wszystkie prace wykonujemy zgodnie z normami bezpieczeństwa i obowiązującymi przepisami.</p>
              </div>
            </div>
            <div class="vf-about-feature">
              <div class="vf-feature-icon" aria-hidden="true">
                <svg width="18" height="18" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
              </div>
              <div>
                <div class="vf-feature-title">Doświadczenie i fachowość</div>
                <p class="vf-feature-text">Wieloletnie doświadczenie naszego zespołu to gwarancja sprawnej i profesjonalnej obsługi.</p>
              </div>
            </div>
            <div class="vf-about-feature">
              <div class="vf-feature-icon" aria-hidden="true">
                <svg width="18" height="18" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <div>
                <div class="vf-feature-title">Niezawodna obsługa</div>
                <p class="vf-feature-text">Dotrzymujemy terminów i słowa danego klientowi. Nasza reputacja jest dla nas priorytetem.</p>
              </div>
            </div>
            <div class="vf-about-feature">
              <div class="vf-feature-icon" aria-hidden="true">
                <svg width="18" height="18" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
              </div>
              <div>
                <div class="vf-feature-title">Transparentne ceny</div>
                <p class="vf-feature-text">Wycena bez niespodzianek. Podajemy ostateczną cenę przed rozpoczęciem pracy.</p>
              </div>
            </div>
          </div>
          <a href="/o-nas" class="btn btn-dark" style="margin-top:8px;">
            Poznaj nas lepiej
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       SERVICES
  ═══════════════════════════════════════════════════════════ -->
  {services.length > 0 && (
    <section class="section section-grey" aria-labelledby="services-heading">
      <div class="container">
        <div class="vf-services-layout">
          <!-- Zdjęcie usług -->
          <div class="vf-services-img">
            <img src={svcImg(0)} alt="Nasze usługi" width="480" height="640" loading="lazy" />
          </div>

          <!-- Karty usług -->
          <div>
            <div class="label">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              Co oferujemy
            </div>
            <h2 id="services-heading" style="margin-bottom:8px;">Nasze usługi</h2>
            <div class="divider"></div>
            <p style="margin-bottom:32px;max-width:52ch;">
              Oferujemy kompleksowy zakres usług dla klientów indywidualnych i biznesowych na terenie {siteConfig.city ?? 'całej Polski'}.
            </p>
            <div class="vf-services-grid">
              {services.map((s: { name: string; slug: string; short_description?: string }, i: number) => (
                <a href={`/uslugi/${s.slug}`} class="vf-service-card" aria-label={`${s.name} — dowiedz się więcej`}>
                  <div class="vf-service-icon" aria-hidden="true">
                    <svg width="26" height="26" fill="none" stroke="var(--accent)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                  </div>
                  <div class="vf-service-name">{s.name}</div>
                  {s.short_description && <p class="vf-service-desc">{s.short_description}</p>}
                  <span class="vf-service-link" aria-hidden="true">
                    Więcej
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════
       PROCESS
  ═══════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="process-heading">
    <div class="container">
      <div class="grid-2">
        <!-- Zdjęcie -->
        <div class="vf-process-img">
          <img src={svcImg(1) ?? FALLBACK_PROCESS} alt="Nasz proces pracy" width="520" height="480" loading="lazy" />
        </div>

        <!-- Kroki -->
        <div>
          <div class="label">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Jak pracujemy
          </div>
          <h2 id="process-heading">Nasz proces</h2>
          <div class="divider"></div>
          <div class="vf-steps">
            <div class="vf-step">
              <div class="vf-step-num" aria-hidden="true">1</div>
              <div>
                <div class="vf-step-title">Konsultacja</div>
                <p class="vf-step-text">Omawiamy Twoje potrzeby i wymagania. Doradzamy najlepsze rozwiązania dopasowane do Twojej sytuacji.</p>
              </div>
            </div>
            <div class="vf-step">
              <div class="vf-step-num" aria-hidden="true">2</div>
              <div>
                <div class="vf-step-title">Planowanie i wycena</div>
                <p class="vf-step-text">Przygotowujemy szczegółowy plan i transparentną wycenę bez ukrytych kosztów. Ustalamy termin realizacji.</p>
              </div>
            </div>
            <div class="vf-step">
              <div class="vf-step-num" aria-hidden="true">3</div>
              <div>
                <div class="vf-step-title">Realizacja</div>
                <p class="vf-step-text">Profesjonalne wykonanie prac przez doświadczonych specjalistów z użyciem sprawdzonych materiałów.</p>
              </div>
            </div>
            <div class="vf-step">
              <div class="vf-step-num" aria-hidden="true">4</div>
              <div>
                <div class="vf-step-title">Odbiór i gwarancja</div>
                <p class="vf-step-text">Wspólny odbiór prac i przekazanie gwarancji. Zostajemy do Twojej dyspozycji po zakończeniu zlecenia.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       WHY CHOOSE US
  ═══════════════════════════════════════════════════════════ -->
  <section class="section section-lite" aria-labelledby="why-heading">
    <div class="container">
      <div class="vf-why-grid">
        <!-- Karty -->
        <div>
          <div class="label">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Dlaczego my
          </div>
          <h2 id="why-heading" style="margin-bottom:8px;">Co nas wyróżnia</h2>
          <div class="divider"></div>
          <div class="vf-why-cards">
            <div class="vf-why-card">
              <div class="vf-why-icon" aria-hidden="true">
                <svg width="22" height="22" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
              </div>
              <div class="vf-why-title">Doświadczenie</div>
              <p class="vf-why-text">Wieloletnia praktyka w branży gwarantuje sprawną i fachową realizację każdego zlecenia.</p>
            </div>
            <div class="vf-why-card">
              <div class="vf-why-icon" aria-hidden="true">
                <svg width="22" height="22" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
