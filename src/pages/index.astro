            </div>
            <div class="vf-why-card">
              <div class="vf-why-icon" aria-hidden="true">
                <svg width="22" height="22" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div class="vf-why-title">Bezpieczeństwo</div>
              <p class="vf-why-text">Wszystkie nasze działania są zgodne z przepisami BHP i normami branżowymi.</p>
            </div>
            <div class="vf-why-card">
              <div class="vf-why-icon" aria-hidden="true">
                <svg width="22" height="22" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
              </div>
              <div class="vf-why-title">Uczciwe ceny</div>
              <p class="vf-why-text">Transparentne wyceny bez niespodzianek. Znasz cenę końcową zanim zaczniemy pracę.</p>
            </div>
          </div>
          <p style="margin-top:28px;font-size:14px;">
            <a href="/kontakt" style="color:var(--accent);font-weight:700;">Skontaktuj się z nami po bezpłatną wycenę →</a>
          </p>
        </div>

        <!-- Zdjęcie -->
        <div class="vf-why-img">
          <img src={svcImg(2) ?? FALLBACK_WHY} alt="Dlaczego wybrać naszą firmę" width="500" height="600" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       STATS — dark section z licznikami
  ═══════════════════════════════════════════════════════════ -->
  <section class="vf-stats section-dark section" aria-label="Osiągnięcia firmy">
    <div class="container">
      <div class="vf-stats-grid">
        {stats.map((stat) => (
          <div class="vf-stat">
            <div class="vf-stat-number">{stat.number}</div>
            <div class="vf-stat-label">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       PHONE CTA
  ═══════════════════════════════════════════════════════════ -->
  {siteConfig.phone && (
    <div class="vf-phone-cta" role="complementary" aria-label="Kontakt telefoniczny">
      <div class="container">
        <div class="vf-phone-cta-inner">
          <div class="vf-phone-icon" aria-hidden="true">
            <svg width="24" height="24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.68A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/></svg>
          </div>
          <div>
            <div class="vf-phone-label">Zadzwoń do nas</div>
            <a
              href={`tel:${siteConfig.phone.replace(/\s/g,'')}`}
              class="vf-phone-number"
              aria-label={`Zadzwoń: ${siteConfig.phone}`}
            >
              {siteConfig.phone}
            </a>
          </div>
          <a href="/kontakt" class="btn btn-dark" style="margin-left:auto;">
            Wyślij wiadomość
          </a>
        </div>
      </div>
    </div>
  )}

  <!-- ═══════════════════════════════════════════════════════════
       PRICING
  ═══════════════════════════════════════════════════════════ -->
  <section class="section section-grey" aria-labelledby="pricing-heading">
    <div class="container">
      <div style="text-align:center;margin-bottom:clamp(32px,4vw,48px);">
        <div class="label" style="justify-content:center;">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Cennik
        </div>
        <h2 id="pricing-heading">Wybierz odpowiedni plan</h2>
        <div class="divider" style="margin:14px auto 0;"></div>
      </div>

      <!-- Toggle monthly/roczny -->
      <div class="vf-pricing-toggle" role="group" aria-label="Wybór okresu rozliczeniowego">
        <span class="vf-toggle-label" id="label-monthly">Miesięcznie</span>
        <button
          class="vf-toggle-switch"
          id="pricing-toggle"
          role="switch"
          aria-checked="false"
          aria-labelledby="label-monthly label-yearly"
        ></button>
        <span class="vf-toggle-label" id="label-yearly">
          Rocznie
          <span class="vf-badge">Oszczędź 25%</span>
        </span>
      </div>

      <div class="grid-3 vf-pricing-grid">
        {pricingTiers.map((tier) => (
          <div class={`vf-pricing-card${tier.featured ? ' vf-pricing-featured' : ''}`}>
            {tier.featured && <div class="vf-pricing-badge">Najpopularniejszy</div>}
            <div class="vf-pricing-name">{tier.name}</div>
            <div class="vf-pricing-tagline">{tier.tagline}</div>
            <div class="vf-pricing-price monthly">
              {tier.price_mo.toLocaleString('pl-PL')} <span>zł / mies.</span>
            </div>
            <div class="vf-pricing-price yearly" style="display:none;">
              {tier.price_yr.toLocaleString('pl-PL')} <span>zł / rok</span>
            </div>
            <p class="vf-pricing-desc">{tier.desc}</p>
            <ul class="vf-pricing-features">
              {tier.features.map((f) => (
                <li class="vf-pricing-feature">
                  <svg width="16" height="16" fill="none" stroke="var(--accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/kontakt" class={tier.featured ? 'btn btn-primary' : 'btn btn-outline'} style="width:100%;justify-content:center;">
              Wybierz plan
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       TESTIMONIALS
  ═══════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="testimonials-heading">
    <div class="container">
      <div style="text-align:center;margin-bottom:clamp(32px,4vw,48px);">
        <div class="label" style="justify-content:center;">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Opinie klientów
        </div>
        <h2 id="testimonials-heading">Co mówią nasi klienci</h2>
        <div class="divider" style="margin:14px auto 0;"></div>
      </div>

      <div class="vf-slider-wrap" aria-label="Opinie klientów">
        <div class="vf-slider" id="testimonials-slider">
          <div class="vf-slider-track" id="testimonials-track" role="list">
            {testimonials.map((t, i) => (
              <div class="vf-testimonial" role="listitem" aria-label={`Opinia ${i+1} z ${testimonials.length}`}>
                <div class="vf-t-stars" aria-label={`Ocena: ${t.rating} na 5`}>
                  {[1,2,3,4,5].map(() => (
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  ))}
                </div>
                <p class="vf-t-quote">"{t.quote}"</p>
                <div class="vf-t-author">
                  <div class="vf-t-avatar" aria-hidden="true">{t.author.charAt(0)}</div>
                  <div>
                    <div class="vf-t-name">{t.author}</div>
                    <div class="vf-t-role">{t.role}</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="vf-slider-dots" role="tablist" aria-label="Nawigacja opinii" id="testimonials-dots">
          {testimonials.map((_, i) => (
            <button
              class={`vf-dot${i === 0 ? ' active' : ''}`}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-label={`Opinia ${i+1}`}
              data-index={i}
            ></button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       BLOG (jeśli są wpisy)
  ═══════════════════════════════════════════════════════════ -->
  {posts.length > 0 && (
    <section class="section section-grey" aria-labelledby="blog-heading">
      <div class="container">
        <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:clamp(28px,4vw,44px);flex-wrap:wrap;">
          <div>
            <div class="label">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              Baza wiedzy
            </div>
            <h2 id="blog-heading" style="margin:0;">Nasze artykuły</h2>
          </div>
          <a href="/blog" class="btn btn-outline">Wszystkie artykuły</a>
        </div>
        <div class="grid-3">
          {posts.slice(0, 3).map((post: { title: string; slug: string; status?: string; created_at?: string }, i: number) => (
            <a href={`/blog/${post.slug}`} class="vf-blog-card" aria-label={post.title}>
              <div class="vf-blog-img-wrap">
                <img
                  src={fb.services[i % fb.services.length]}
                  alt={post.title}
                  width="600" height="338"
                  loading="lazy"
                  style="width:100%;aspect-ratio:16/9;object-fit:cover;"
                />
              </div>
              <div class="vf-blog-body">
                <span class="vf-blog-badge">Poradnik</span>
                {post.created_at && (
                  <div class="vf-blog-date">
                    {new Date(post.created_at).toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </div>
                )}
                <div class="vf-blog-title">{post.title}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════
       FAQ
  ═══════════════════════════════════════════════════════════ -->
  {faqItems.length > 0 && (
    <section class="section" aria-labelledby="faq-heading">
      <div class="container" style="max-width:800px;">
        <div style="text-align:center;margin-bottom:clamp(28px,4vw,44px);">
          <div class="label" style="justify-content:center;">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            FAQ
          </div>
          <h2 id="faq-heading">Najczęstsze pytania</h2>
        </div>
        <div class="vf-faq-list" role="list">
          {faqItems.map((item, i) => (
            <div class="vf-faq-item" role="listitem">
              <button
                class="vf-faq-q"
                aria-expanded="false"
                aria-controls={`faq-a-${i}`}
                id={`faq-q-${i}`}
              >
                {item.question}
                <svg class="vf-faq-chevron" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="vf-faq-a" id={`faq-a-${i}`} role="region" aria-labelledby={`faq-q-${i}`}>
                <div class="vf-faq-a-inner">{item.answer}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════
       LOKALIZACJE
  ═══════════════════════════════════════════════════════════ -->
  {locations.length > 0 && (
    <section class="section section-lite" aria-labelledby="locations-heading">
      <div class="container">
        <div style="text-align:center;margin-bottom:clamp(24px,3vw,36px);">
          <div class="label" style="justify-content:center;">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Zasięg
          </div>
          <h2 id="locations-heading">Obsługiwane lokalizacje</h2>
        </div>
        <div class="vf-location-tags" role="list">
          {locations.map((loc: { city: string; slug: string }) => (
            <a href={`/lokalizacje/${loc.slug}`} class="vf-location-tag" role="listitem">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {loc.city}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════
       FINAL CTA
  ═══════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="cta-heading">
    <div class="container" style="text-align:center;max-width:700px;">
      <div class="vf-cta-icon" aria-hidden="true">
        <svg width="28" height="28" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
      </div>
      {siteConfig.email && (
        <div class="vf-cta-email">{siteConfig.email}</div>
      )}
      <h2 id="cta-heading">Skontaktuj się z nami</h2>
      <div class="divider" style="margin:16px auto 20px;"></div>
      <p style="margin:0 auto 32px;">
        Gotowy na profesjonalną obsługę? Zadzwoń lub napisz — odpowiemy szybko i bezpłatnie wycenimy Twoje zlecenie.
      </p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
        <a href="/kontakt" class="btn btn-primary">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Bezpłatna wycena
        </a>
        {siteConfig.phone && (
          <a href={`tel:${siteConfig.phone.replace(/\s/g,'')}`} class="btn btn-outline">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.68A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/></svg>
            {siteConfig.phone}
          </a>
        )}
      </div>
    </div>
  </section>
</ClientLayout>

<!-- ═══════════════════════════════════════════════════════════
     PAGE-LEVEL STYLES
═══════════════════════════════════════════════════════════ -->
<style>
  /* ── HERO ─────────────────────────────────────────────────── */
  .vf-hero {
    position: relative;
    min-height: clamp(480px, 70vh, 760px);
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .vf-hero-bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
  }
  .vf-hero-bg::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(100deg, rgba(16,20,24,0.78) 0%, rgba(16,20,24,0.3) 100%);
  }
  .vf-hero-content {
    position: relative; z-index: 1;
    padding: 80px 0;
  }
  .vf-hero h1 {
    color: #fff;
    font-size: clamp(34px, 5.5vw, 62px);
    font-weight: 900;
    line-height: 1.07;
    margin-bottom: 20px;
    max-width: 16ch;
  }
  .vf-hero p {
    color: rgba(255,255,255,0.8);
    font-size: clamp(15px, 1.6vw, 18px);
    line-height: 1.65;
    margin-bottom: 34px;
    max-width: 54ch;
  }
  .vf-hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-h);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 20px;
  }
  .vf-hero-eyebrow svg { width: 14px; height: 14px; }
  .vf-hero-btns { display: flex; gap: 14px; flex-wrap: wrap; }

  /* ── INTRO ────────────────────────────────────────────────── */
  .vf-intro-grid {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: clamp(24px, 5vw, 64px);
    align-items: start;
  }
  .vf-intro-points { background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow); }
  .vf-intro-point {
    display: flex;
    gap: 18px;
    padding: clamp(18px, 2.5vw, 26px);
    border-bottom: 1px solid var(--border);
    align-items: flex-start;
  }
  .vf-intro-point:last-child { border-bottom: none; }
  .vf-intro-icon {
    width: 48px; height: 48px; flex-shrink: 0;
    background: var(--accent);
    border-radius: var(--radius);
    display: flex; align-items: center; justify-content: center;
  }
  .vf-intro-title { font-family: var(--font-h); font-size: 16px; font-weight: 700; color: var(--heading); margin-bottom: 4px; }
  .vf-intro-text { font-size: 14px; color: var(--body); line-height: 1.6; max-width: 48ch; }
  .vf-intro-form {
    background: var(--heading);
    border-radius: var(--radius-lg);
    padding: clamp(24px, 3vw, 36px);
    box-shadow: var(--shadow-lg);
  }
  .vf-intro-form-title {
    font-family: var(--font-h);
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 800;
    color: #fff;
    margin-bottom: 22px;
    line-height: 1.2;
  }
  .vf-form { display: flex; flex-direction: column; gap: 0; }
  .vf-field { margin-bottom: 14px; }
  .vf-label { display: block; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: rgba(255,255,255,0.6); margin-bottom: 6px; }
  .vf-input, .vf-select {
    width: 100%;
    padding: 13px 16px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius);
    color: #fff;
    font-size: 14px;
    transition: border-color var(--transition);
  }
  .vf-input::placeholder { color: rgba(255,255,255,0.3); }
  .vf-input:focus, .vf-select:focus { outline: none; border-color: var(--accent); }
  .vf-select { appearance: none; }
  .vf-select option { background: var(--heading); }
  .vf-form-btn { width: 100%; justify-content: center; margin-top: 4px; }

  /* ── ABOUT ────────────────────────────────────────────────── */
  .vf-about-img-wrap { position: relative; }
  .vf-about-img-wrap img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }
  .vf-about-rating {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    padding: 8px 18px 8px 10px;
    margin-top: 16px;
    box-shadow: var(--shadow);
  }
  .vf-rating-num { font-family: var(--font-h); font-size: 18px; font-weight: 900; color: var(--heading); }
  .vf-stars { display: flex; gap: 2px; }
  .vf-rating-label { font-size: 12px; color: var(--body); }
  .vf-about-features { display: flex; flex-direction: column; }
  .vf-about-feature {
    display: flex; gap: 14px; align-items: flex-start;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }
  .vf-about-feature:first-child { border-top: 1px solid var(--border); }
  .vf-feature-icon {
    width: 36px; height: 36px; flex-shrink: 0;
    background: rgba(255,98,41,0.1);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .vf-feature-title { font-family: var(--font-h); font-size: 14px; font-weight: 700; color: var(--heading); margin-bottom: 2px; }
  .vf-feature-text { font-size: 13px; color: var(--body); line-height: 1.55; max-width: 44ch; }

  /* ── SERVICES ─────────────────────────────────────────────── */
  .vf-services-layout { display: grid; grid-template-columns: 0.75fr 1.25fr; gap: clamp(24px, 5vw, 56px); align-items: start; }
  .vf-services-img { border-radius: var(--radius-lg); overflow: hidden; }
  .vf-services-img img { width: 100%; aspect-ratio: 3/4; object-fit: cover; }
  .vf-services-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .vf-service-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: clamp(18px, 2vw, 24px);
