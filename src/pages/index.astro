</style>

<script>
  // ── Counter animation ────────────────────────────────────
  function animateCounters() {
    document.querySelectorAll<HTMLElement>('[data-counter]').forEach((el) => {
      const target = parseInt(el.dataset.counter ?? '0', 10);
      const suffix = el.dataset.suffix ?? '';
      const duration = 1800;
      const start = performance.now();
      const tick = (now: number) => {
        const p = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 4);
        el.textContent = Math.round(target * eased).toLocaleString('pl-PL') + suffix;
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    });
  }
  const statsEl = document.querySelector('.vf-stats');
  if (statsEl) {
    new IntersectionObserver((entries, obs) => {
      if (entries[0].isIntersecting) { animateCounters(); obs.disconnect(); }
    }, { threshold: 0.3 }).observe(statsEl);
  }

  // ── Pricing toggle ───────────────────────────────────────
  const toggle = document.getElementById('pricing-toggle') as HTMLButtonElement | null;
  toggle?.addEventListener('click', () => {
    const isYearly = toggle.classList.toggle('active');
    toggle.setAttribute('aria-checked', String(isYearly));
    document.querySelectorAll<HTMLElement>('.monthly').forEach(el => el.style.display = isYearly ? 'none' : '');
    document.querySelectorAll<HTMLElement>('.yearly').forEach(el => el.style.display = isYearly ? '' : 'none');
  });

  // ── Testimonials slider ──────────────────────────────────
  const track = document.getElementById('testimonials-track') as HTMLElement | null;
  const dots = document.querySelectorAll<HTMLButtonElement>('.vf-dot');
  let current = 0;

  function slideTo(i: number) {
    if (!track) return;
    current = i;
    const card = track.querySelector<HTMLElement>('.vf-testimonial');
    if (!card) return;
    const w = card.offsetWidth + 24;
    track.style.transform = `translateX(-${i * w}px)`;
    dots.forEach((d, idx) => {
      d.classList.toggle('active', idx === i);
      d.setAttribute('aria-selected', String(idx === i));
    });
  }
  dots.forEach((dot, i) => dot.addEventListener('click', () => slideTo(i)));

  // Auto-advance every 4s
  let timer = setInterval(() => {
    const next = (current + 1) % dots.length;
    slideTo(next);
  }, 4000);
  track?.closest('.vf-slider-wrap')?.addEventListener('mouseenter', () => clearInterval(timer));
  track?.closest('.vf-slider-wrap')?.addEventListener('mouseleave', () => {
    timer = setInterval(() => slideTo((current + 1) % dots.length), 4000);
  });

  // ── FAQ accordion ────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.vf-faq-q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest<HTMLElement>('.vf-faq-item');
      if (!item) return;
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.vf-faq-item.open').forEach(el => {
        el.classList.remove('open');
        el.querySelector('button')?.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
