---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import {
  createPageDraftVersion,
  createSystemLog,
  getPageById,
  getPageVersions,
  publishPageVersionToBase,
  saveContentDiff,
  updatePageVersionStatus,
} from '../../../lib/client-data';

const pageId = Astro.params.id;

if (!pageId) {
  throw new Error('Brak pageId');
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = String(formData.get('action') ?? '');

  if (action === 'create-page-draft') {
    const clientId = String(formData.get('client_id') ?? '');
    const pageSlug = String(formData.get('page_slug') ?? '');
    const oldBody = String(formData.get('old_body') ?? '');
    const newBody = String(formData.get('body_markdown') ?? '');

    const version = await createPageDraftVersion({
      page_id: pageId,
      body_markdown: newBody,
      metadata: {
        page_slug: pageSlug,
      },
      source: 'operator_panel',
    });

    await saveContentDiff({
      before_json: {
        body_markdown: oldBody,
      },
      after_json: {
        body_markdown: newBody,
      },
      diff_summary: `Utworzono draft wersji dla strony ${pageSlug}`,
    });

    await createSystemLog({
      client_id: clientId,
      log_type: 'page_draft_created',
      message: `Utworzono draft version v${version.version_no} dla strony ${pageSlug}`,
      payload_json: {
        page_id: pageId,
        version_id: version.id,
      },
    });

    return Astro.redirect(`/admin/pages/${pageId}?draft_created=1`);
  }

  if (action === 'approve-page-version') {
    const versionId = String(formData.get('version_id') ?? '');
    const clientId = String(formData.get('client_id') ?? '');

    const version = await updatePageVersionStatus(versionId, 'approved');

    await createSystemLog({
      client_id: clientId,
      log_type: 'page_version_approved',
      message: `Zatwierdzono page version v${version.version_no}`,
      payload_json: {
        version_id: versionId,
      },
    });

    return Astro.redirect(`/admin/pages/${pageId}?approved=1`);
  }

  if (action === 'publish-page-version') {
    const versionId = String(formData.get('version_id') ?? '');
    const clientId = String(formData.get('client_id') ?? '');
    const pageBaseId = String(formData.get('page_base_id') ?? '');

    const versions = await getPageVersions(pageId);
    const selectedVersion = versions.find((v) => v.id === versionId);

    if (!selectedVersion) {
      throw new Error('Nie znaleziono wybranej wersji strony');
    }

    await publishPageVersionToBase(pageBaseId, selectedVersion.body_markdown ?? '');
    const version = await updatePageVersionStatus(versionId, 'published');

    await createSystemLog({
      client_id: clientId,
      log_type: 'page_version_published',
      message: `Opublikowano page version v${version.version_no}`,
      payload_json: {
        version_id: versionId,
        page_id: pageBaseId,
      },
    });

    return Astro.redirect(`/admin/pages/${pageId}?published=1`);
  }
}

const page = await getPageById(pageId);
const versions = await getPageVersions(pageId);

const url = new URL(Astro.request.url);
const draftCreated = url.searchParams.get('draft_created');
const approved = url.searchParams.get('approved');
const published = url.searchParams.get('published');
---

<AdminLayout title={`Admin — strona ${page.slug}`}>
  <div class="card">
    <h1>Strona: {page.slug}</h1>
    <p class="muted">Content Studio MVP dla stron stałych.</p>

    {draftCreated && <p><strong>Utworzono draft wersji strony.</strong></p>}
    {approved && <p><strong>Zatwierdzono wersję strony.</strong></p>}
    {published && <p><strong>Opublikowano wersję strony.</strong></p>}
  </div>

  <div class="grid-2">
    <div class="card">
      <h2>Aktualna treść bazowa</h2>
      <p><strong>Tytuł:</strong> {page.title ?? '-'}</p>
      <p><strong>Slug:</strong> {page.slug}</p>

      <pre style="white-space:pre-wrap;">{page.body_markdown ?? '-'}</pre>
    </div>

    <div class="card">
      <h2>Utwórz draft version</h2>

      <form method="POST">
        <input type="hidden" name="action" value="create-page-draft" />
        <input type="hidden" name="client_id" value={page.client_id} />
        <input type="hidden" name="page_slug" value={page.slug} />
        <input type="hidden" name="old_body" value={page.body_markdown ?? ''} />

        <label class="label">
          Nowa treść strony
          <textarea class="textarea" name="body_markdown">{page.body_markdown ?? ''}</textarea>
        </label>

        <button class="btn" type="submit">Utwórz draft</button>
      </form>
    </div>
  </div>

  <div class="card">
    <h2>Wersje strony</h2>

    {versions.length === 0 ? (
      <p class="muted">Brak wersji strony.</p>
    ) : (
      <table class="table">
        <thead>
          <tr>
            <th>Version</th>
            <th>Status</th>
            <th>Treść</th>
            <th>Akcje</th>
          </tr>
        </thead>
        <tbody>
          {versions.map((version) => (
            <tr>
              <td>v{version.version_no}</td>
              <td><span class="pill">{version.status}</span></td>
              <td>{version.body_markdown?.slice(0, 160) ?? '-'}</td>
              <td>
                <div style="display:flex; gap:8px; flex-wrap:wrap;">
                  {version.status === 'draft' && (
                    <form method="POST">
                      <input type="hidden" name="action" value="approve-page-version" />
                      <input type="hidden" name="version_id" value={version.id} />
                      <input type="hidden" name="client_id" value={page.client_id} />
                      <button class="btn" type="submit">Approve</button>
                    </form>
                  )}

                  {version.status === 'approved' && (
                    <form method="POST">
                      <input type="hidden" name="action" value="publish-page-version" />
                      <input type="hidden" name="version_id" value={version.id} />
                      <input type="hidden" name="client_id" value={page.client_id} />
                      <input type="hidden" name="page_base_id" value={page.id} />
                      <button class="btn btn-secondary" type="submit">Publish</button>
                    </form>
                  )}
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}

    <p style="margin-top:16px;">
      <a href={`/admin/pages/${page.id}/diffs`}>Zobacz diffy strony</a>
    </p>
  </div>
</AdminLayout>