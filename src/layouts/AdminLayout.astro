---
type Props = {
  title: string;
};

const { title } = Astro.props;

const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/admin',                label: 'Klienci',        icon: 'clients' },
  { href: '/admin/changes',        label: 'Change Center',  icon: 'changes' },
  { href: '/admin/jobs',           label: 'Jobs',           icon: 'jobs' },
  { href: '/admin/deployments',    label: 'Deployments',    icon: 'deploy' },
  { href: '/admin/indexing',       label: 'Indexing',       icon: 'index' },
  { href: '/admin/design-catalog', label: 'Design Catalog', icon: 'design' },
  { href: '/admin/definition-of-done', label: 'DoD',        icon: 'done' },
];

function isActive(href: string) {
  if (href === '/admin') return currentPath === '/admin';
  return currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Fabryka Stron</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style is:global>
      /* ── Supabase tokens ── */
      :root {
        --sb-base:       #121212;
        --sb-raised:     #1a1a1a;
        --sb-overlay:    #0f0f0f;
        --sb-border:     #1a1a1a;
        --sb-border-2:   #262626;
        --sb-green:      #3db576;
        --sb-green-dim:  rgba(61,181,118,.12);
        --sb-green-text: #4eca88;
        --sb-text-1:     #e9e9e9;
        --sb-text-2:     #a2a2a2;
        --sb-text-3:     #525252;
        --sb-text-4:     #323232;
        --sb-danger:     #e05c5c;
        --sb-warning:    #d4955a;
        --sb-wrap:       1280px;
        --sb-sidebar:    220px;
        --sb-header:     44px;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html { height: 100%; }

      body {
        min-height: 100dvh;
        font-family: 'Inter', -apple-system, sans-serif;
        font-size: 13px;
        font-weight: 400;
        line-height: 1.5;
        background: var(--sb-base);
        color: var(--sb-text-2);
        -webkit-font-smoothing: antialiased;
      }

      a { color: var(--sb-green-text); text-decoration: none; }
      a:hover { color: #fff; }

      strong { color: var(--sb-text-1); font-weight: 500; }
      code {
        font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
        font-size: 11px;
        background: var(--sb-overlay);
        border: 1px solid var(--sb-border-2);
        border-radius: 3px;
        padding: 1px 5px;
        color: var(--sb-text-2);
      }
      pre {
        background: var(--sb-overlay);
        border: 1px solid var(--sb-border);
        border-radius: 6px;
        padding: 16px;
        overflow-x: auto;
        font-size: 12px;
        line-height: 1.7;
        color: var(--sb-text-2);
        font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
      }

      /* ── Shell layout ── */
      .sb-shell {
        display: flex;
        flex-direction: column;
        min-height: 100dvh;
      }

      /* ── Top header bar ── */
      .sb-header {
        height: var(--sb-header);
        border-bottom: 1px solid var(--sb-border);
        background: var(--sb-base);
        display: flex;
        align-items: center;
        padding: 0 16px;
        gap: 16px;
        flex-shrink: 0;
        position: sticky;
        top: 0;
        z-index: 40;
      }
      .sb-logo {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        font-weight: 600;
        color: var(--sb-text-1);
        white-space: nowrap;
        flex-shrink: 0;
      }
      .sb-logo-dot {
        width: 20px;
        height: 20px;
        border-radius: 4px;
        background: var(--sb-green);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .sb-logo-dot svg {
        width: 12px;
        height: 12px;
        fill: #000;
      }
      .sb-header-sep {
        width: 1px;
        height: 16px;
        background: var(--sb-border-2);
        flex-shrink: 0;
      }
      .sb-header-title {
        font-size: 13px;
        color: var(--sb-text-3);
        flex: 1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      /* ── Body: sidebar + main ── */
      .sb-body {
        display: flex;
        flex: 1;
        overflow: hidden;
      }

      /* ── Sidebar ── */
      .sb-sidebar {
        width: var(--sb-sidebar);
        flex-shrink: 0;
        border-right: 1px solid var(--sb-border);
        padding: 16px 8px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        position: sticky;
        top: var(--sb-header);
        height: calc(100dvh - var(--sb-header));
        overflow-y: auto;
      }
      .sb-sidebar::-webkit-scrollbar { display: none; }

      .sb-nav-section {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--sb-text-4);
        padding: 12px 8px 6px;
      }
      .sb-nav-section:first-child { padding-top: 0; }

      .sb-nav-item {
        display: flex;
        align-items: center;
        gap: 8px;
        height: 32px;
        padding: 0 8px;
        border-radius: 5px;
        font-size: 13px;
        font-weight: 400;
        color: var(--sb-text-3);
        transition: background 100ms, color 100ms;
        white-space: nowrap;
        overflow: hidden;
      }
      .sb-nav-item:hover {
        background: var(--sb-raised);
        color: var(--sb-text-2);
      }
      .sb-nav-item.active {
        background: var(--sb-green-dim);
        color: var(--sb-green-text);
        font-weight: 500;
      }
      .sb-nav-item.active .sb-nav-icon { color: var(--sb-green); }

      .sb-nav-icon {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
        color: var(--sb-text-4);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .sb-nav-icon svg {
        width: 14px;
        height: 14px;
        stroke: currentColor;
        fill: none;
        stroke-width: 1.5;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      /* ── Main content ── */
      .sb-main {
        flex: 1;
        overflow-y: auto;
        padding: 24px 28px;
        max-width: calc(var(--sb-wrap) - var(--sb-sidebar));
      }

      /* ── Page header ── */
      .page-header {
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--sb-border);
      }
      .page-title {
        font-size: 15px;
        font-weight: 600;
        color: var(--sb-text-1);
        margin-bottom: 4px;
      }
      .page-desc {
        font-size: 13px;
        color: var(--sb-text-3);
      }

      /* ── Cards / panels ── */
      .card {
        background: var(--sb-overlay);
        border: 1px solid var(--sb-border);
        border-radius: 6px;
        padding: 16px;
        margin-bottom: 12px;
      }
      .card h1 {
        font-size: 15px;
        font-weight: 600;
        color: var(--sb-text-1);
        margin-bottom: 6px;
      }
      .card h2 {
        font-size: 13px;
        font-weight: 600;
        color: var(--sb-text-1);
        margin-bottom: 12px;
      }
      .card h3 {
        font-size: 12px;
        font-weight: 600;
        color: var(--sb-text-2);
        margin-bottom: 8px;
      }

      /* ── Grid ── */
      .grid-2 {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 12px;
      }
      @media (max-width: 900px) {
        .grid-2 { grid-template-columns: 1fr; }
      }

      /* ── Muted text ── */
      .muted { color: var(--sb-text-3); font-size: 12px; }

      /* ── Form elements ── */
      .label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        color: var(--sb-text-2);
        margin-bottom: 12px;
      }
      .input,
      .textarea,
      .select {
        display: block;
        width: 100%;
        padding: 7px 10px;
        background: var(--sb-base);
        border: 1px solid var(--sb-border-2);
        border-radius: 5px;
        color: var(--sb-text-1);
        font-family: inherit;
        font-size: 13px;
        margin-top: 4px;
        transition: border-color 150ms;
        -webkit-appearance: none;
      }
      .input:focus, .textarea:focus, .select:focus {
        outline: 2px solid var(--sb-green);
        outline-offset: 2px;
        border-color: var(--sb-green);
      }
      .input::placeholder, .textarea::placeholder { color: var(--sb-text-4); }
      .textarea { min-height: 100px; resize: vertical; }

      /* ── Buttons ── */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 30px;
        padding: 0 12px;
        border-radius: 5px;
        background: var(--sb-green);
        border: 1px solid transparent;
        color: #000;
        font-family: inherit;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: background 150ms;
        white-space: nowrap;
        flex-shrink: 0;
      }
      .btn:hover { background: #4eca88; }
      .btn:focus-visible { outline: 2px solid var(--sb-green); outline-offset: 2px; }
      .btn:disabled { opacity: .4; cursor: not-allowed; }

      .btn-secondary {
        background: var(--sb-raised);
        border-color: var(--sb-border-2);
        color: var(--sb-text-2);
      }
      .btn-secondary:hover { background: #2a2a2a; color: var(--sb-text-1); }

      .btn-ghost {
        background: transparent;
        border-color: transparent;
        color: var(--sb-text-3);
      }
      .btn-ghost:hover { background: var(--sb-raised); color: var(--sb-text-2); }

      .btn-danger {
        background: transparent;
        border-color: var(--sb-danger);
        color: var(--sb-danger);
      }
      .btn-danger:hover { background: rgba(224,92,92,.1); }

      /* ── Table ── */
      .table { width: 100%; border-collapse: collapse; }
      .table th {
        text-align: left;
        padding: 6px 12px;
        font-size: 11px;
        font-weight: 600;
        color: var(--sb-text-3);
        text-transform: uppercase;
        letter-spacing: .06em;
        border-bottom: 1px solid var(--sb-border);
        white-space: nowrap;
      }
      .table td {
        padding: 9px 12px;
        font-size: 13px;
        color: var(--sb-text-2);
        border-bottom: 1px solid var(--sb-border);
        vertical-align: top;
      }
      .table tr:last-child td { border-bottom: none; }
      .table tbody tr:hover td { background: var(--sb-raised); }

      /* ── Pills / Badges ── */
      .pill {
        display: inline-flex;
        align-items: center;
        height: 18px;
        padding: 0 7px;
        border-radius: 3px;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: .04em;
        text-transform: uppercase;
        background: var(--sb-raised);
        border: 1px solid var(--sb-border-2);
        color: var(--sb-text-3);
        white-space: nowrap;
      }
      .pill-green  { background: var(--sb-green-dim); border-color: rgba(61,181,118,.25); color: var(--sb-green-text); }
      .pill-red    { background: rgba(224,92,92,.1);  border-color: rgba(224,92,92,.25);  color: var(--sb-danger); }
      .pill-yellow { background: rgba(212,149,90,.1); border-color: rgba(212,149,90,.25); color: var(--sb-warning); }

      /* ── Alerts ── */
      .alert {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 10px 14px;
        border-radius: 5px;
        font-size: 13px;
        margin-bottom: 12px;
        border: 1px solid;
      }
      .alert-success { background: var(--sb-green-dim); border-color: rgba(61,181,118,.25); color: var(--sb-green-text); }
      .alert-warning { background: rgba(212,149,90,.1); border-color: rgba(212,149,90,.2); color: var(--sb-warning); }
      .alert-danger  { background: rgba(224,92,92,.1); border-color: rgba(224,92,92,.2); color: var(--sb-danger); }
      .alert-info    { background: rgba(61,181,118,.06); border-color: var(--sb-border-2); color: var(--sb-text-2); }

      /* ── Details ── */
      details { margin-top: 8px; }
      summary { font-size: 12px; color: var(--sb-text-3); cursor: pointer; padding: 4px 0; user-select: none; }
      summary:hover { color: var(--sb-text-2); }
    </style>
  </head>
  <body>
    <div class="sb-shell">
      <!-- Top bar -->
      <header class="sb-header">
        <div class="sb-logo">
          <div class="sb-logo-dot">
            <svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          Fabryka Stron
        </div>
        <div class="sb-header-sep"></div>
        <div class="sb-header-title">{title}</div>
      </header>

      <div class="sb-body">
        <!-- Sidebar -->
        <nav class="sb-sidebar">
          <div class="sb-nav-section">Panel</div>

          {navItems.map((item) => (
            <a href={item.href} class={`sb-nav-item${isActive(item.href) ? ' active' : ''}`}>
              <span class="sb-nav-icon">
                {item.icon === 'clients' && (
                  <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
                )}
                {item.icon === 'changes' && (
                  <svg viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                )}
                {item.icon === 'jobs' && (
                  <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                )}
                {item.icon === 'deploy' && (
                  <svg viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                )}
                {item.icon === 'index' && (
                  <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35M11 8v3M11 14h.01"/></svg>
                )}
                {item.icon === 'design' && (
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/></svg>
                )}
                {item.icon === 'done' && (
                  <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                )}
              </span>
              {item.label}
            </a>
          ))}
        </nav>

        <!-- Main -->
        <main class="sb-main">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
