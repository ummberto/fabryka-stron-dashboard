---
type Props = {
  title: string;
  description?: string;
};

const {
  title,
  description = 'Strona wygenerowana w Fabryce Stron v3',
} = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        --bg: #ffffff;
        --text: #0f172a;
        --muted: #475569;
        --line: #e2e8f0;
        --brand: #1d4ed8;
        --wrap: 1120px;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Inter, Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }

      a {
        color: var(--brand);
        text-decoration: none;
      }

      .container {
        max-width: var(--wrap);
        margin: 0 auto;
        padding: 0 20px;
      }

      header {
        border-bottom: 1px solid var(--line);
        background: #fff;
      }

      .header-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 0;
      }

      .logo {
        font-weight: 700;
        font-size: 20px;
      }

      nav a {
        margin-left: 18px;
        color: var(--text);
      }

      .hero {
        padding: 72px 0 40px;
      }

      .hero h1 {
        font-size: 44px;
        line-height: 1.1;
        margin-bottom: 16px;
      }

      .hero p {
        max-width: 720px;
        color: var(--muted);
        font-size: 18px;
      }

      .section {
        padding: 32px 0 56px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
      }

      .card {
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 20px;
      }

      .card h3 {
        margin-top: 0;
        margin-bottom: 10px;
      }

      .muted {
        color: var(--muted);
      }

      .cta {
        display: inline-block;
        margin-top: 18px;
        padding: 12px 18px;
        border-radius: 10px;
        background: var(--brand);
        color: white;
        font-weight: 600;
      }

      footer {
        border-top: 1px solid var(--line);
        padding: 28px 0;
        margin-top: 50px;
      }

      @media (max-width: 900px) {
        .grid {
          grid-template-columns: 1fr;
        }

        .hero h1 {
          font-size: 34px;
        }

        .header-inner {
          flex-direction: column;
          align-items: flex-start;
          gap: 12px;
        }

        nav a {
          margin-left: 0;
          margin-right: 16px;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>